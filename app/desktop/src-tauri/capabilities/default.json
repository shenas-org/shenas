{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "remote": {
    "urls": [
      "http://localhost:*",
      "http://127.0.0.1:*",
      "https://localhost:*",
      "https://127.0.0.1:*"
    ]
  },
  "permissions": [
    "core:default",
    {
      "identifier": "shell:allow-open",
      "allow": [
        { "url": "https://shenas.net/**" },
        { "url": "https://*.shenas.net/**" }
      ]
    },
    "shell:allow-spawn",
    "shell:allow-execute",
    "shell:allow-stdin-write",
    "shell:allow-kill",
    {
      "identifier": "shell:default",
      "allow": [
        {
          "name": "binaries/shenas",
          "sidecar": true,
          "args": true
        },
        {
          "name": "binaries/shenas-scheduler",
          "sidecar": true,
          "args": true
        }
      ]
    }
  ]
}
