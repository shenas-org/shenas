pkgname=shenas-desktop
pkgver=0.21.2
pkgrel=1
pkgdesc="Desktop app for the shenas metrics platform"
arch=('x86_64')
url="https://github.com/shenas-net/shenas"
license=('MIT')
depends=('webkit2gtk-4.1' 'gtk3')
makedepends=('cargo' 'nodejs' 'npm')
source=()

build() {
    cd "$startdir"
    npm install
    npx tauri build --no-bundle
}

package() {
    install -Dm755 "$startdir/src-tauri/target/release/shenas-desktop" "$pkgdir/usr/bin/shenas-desktop"
    install -Dm755 "$startdir/src-tauri/binaries/shenas-x86_64-unknown-linux-gnu" "$pkgdir/usr/bin/shenas"
    install -Dm755 "$startdir/src-tauri/binaries/shenasctl-x86_64-unknown-linux-gnu" "$pkgdir/usr/bin/shenasctl"
    install -Dm755 "$startdir/src-tauri/binaries/shenas-scheduler-x86_64-unknown-linux-gnu" "$pkgdir/usr/bin/shenas-scheduler"
    install -Dm644 "$startdir/src-tauri/icons/icon.png" "$pkgdir/usr/share/pixmaps/shenas-desktop.png"
    install -Dm644 /dev/stdin "$pkgdir/usr/share/applications/shenas-desktop.desktop" <<EOF
[Desktop Entry]
Name=shenas
Comment=Health and finance metrics platform
Exec=shenas-desktop
Icon=shenas-desktop
Terminal=false
Type=Application
Categories=Utility;
EOF
}
