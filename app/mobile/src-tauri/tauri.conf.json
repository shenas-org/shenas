{
  "$schema": "https://raw.githubusercontent.com/nicegui-reference/tauri-v2-schemas/main/tauri.conf.json",
  "productName": "shenas",
  "version": "0.1.0",
  "identifier": "com.shenas.mobile",
  "build": {
    "frontendDist": "../mobile-dist",
    "devUrl": "http://localhost:5173"
  },
  "app": {
    "windows": [
      {
        "title": "shenas",
        "width": 400,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self' http://localhost:5173; connect-src 'self' http://localhost:5173 ws://localhost:5173 http://localhost:7280 http://127.0.0.1:7280; script-src 'self' 'unsafe-inline' http://localhost:5173; style-src 'self' 'unsafe-inline' http://localhost:5173"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/256x256.png",
      "icons/icon.png"
    ]
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}
