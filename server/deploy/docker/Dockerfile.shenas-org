FROM node:22-slim AS build
WORKDIR /app
COPY server/shenas.org/package.json server/shenas.org/package-lock.json* ./
RUN npm ci || npm install
COPY server/shenas.org/ .
RUN npm run build

FROM nginx:1-alpine
RUN rm /etc/nginx/conf.d/default.conf
COPY server/shenas.org/nginx.conf /etc/nginx/conf.d/shenas.conf
COPY --from=build /app/dist /usr/share/nginx/html
EXPOSE 80
