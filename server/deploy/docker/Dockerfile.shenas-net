FROM node:22-slim AS build
WORKDIR /app
COPY server/shenas.net/package.json server/shenas.net/package-lock.json ./
RUN npm ci
COPY server/shenas.net/ .
RUN npm run build

FROM node:22-slim
WORKDIR /app
COPY --from=build /app/dist ./dist
COPY --from=build /app/node_modules ./node_modules
ENV HOST=0.0.0.0
ENV PORT=80
EXPOSE 80
CMD ["node", "dist/server/entry.mjs"]
