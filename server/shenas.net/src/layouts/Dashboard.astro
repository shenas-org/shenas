---
interface Props {
  title: string;
  description: string;
  active: "overview" | "devices";
}

const { title, description, active } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" href="/logo-192.png" />
    <title>{title}</title>
  </head>
  <body>
    <div class="dashboard-layout">
      <aside class="dashboard-sidebar">
        <a href="/" class="brand">
          <img src="/favicon.svg" alt="shenas" width="28" height="28" />
          <span>shenas</span>
        </a>
        <nav class="dashboard-nav">
          <a href="/dashboard" class:list={["nav-item", { active: active === "overview" }]}>
            <span class="nav-icon">🏠</span>
            <span>Overview</span>
          </a>
          <a href="/devices" class:list={["nav-item", { active: active === "devices" }]}>
            <span class="nav-icon">💻</span>
            <span>Devices</span>
          </a>
        </nav>
        <div class="dashboard-footer">
          <a href="/api/auth/logout" class="nav-item logout">
            <span class="nav-icon">↩</span>
            <span>Logout</span>
          </a>
        </div>
      </aside>
      <main class="dashboard-main">
        <slot />
      </main>
    </div>
  </body>
</html>

<style is:global>
  *,
  *::before,
  *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  :root {
    --color-bg: #faf8f5;
    --color-bg-elevated: #f3f0eb;
    --color-bg-card: #fff;
    --color-surface: #edeae4;
    --color-border: #d8d4cc;
    --color-text: #2c2c28;
    --color-text-muted: #8a8780;
    --color-accent: #728f67;
    --color-accent-light: #628261;
    --color-accent-glow: rgba(114, 143, 103, 0.12);
    --color-green: #628261;
    --color-warm: #5a5850;
    --font-sans: Arial, Helvetica, sans-serif;
    --font-mono: "JetBrains Mono", "Fira Code", monospace;
  }

  html {
    font-family: var(--font-sans);
    background: var(--color-bg);
    color: var(--color-text);
    -webkit-font-smoothing: antialiased;
  }

  body {
    min-height: 100vh;
  }

  a {
    color: var(--color-accent);
    text-decoration: none;
  }
</style>

<style>
  .dashboard-layout {
    display: grid;
    grid-template-columns: 240px 1fr;
    min-height: 100vh;
  }

  .dashboard-sidebar {
    background: var(--color-bg-elevated);
    border-right: 1px solid var(--color-border);
    display: flex;
    flex-direction: column;
    padding: 1.5rem 0;
  }

  .brand {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0 1.5rem 1.5rem;
    color: var(--color-text);
    font-weight: 600;
    font-size: 1.1rem;
    border-bottom: 1px solid var(--color-border);
    margin-bottom: 1rem;
  }

  .dashboard-nav {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    flex: 1;
    padding: 0 0.75rem;
  }

  .dashboard-footer {
    padding: 0.75rem;
    border-top: 1px solid var(--color-border);
    margin-top: 1rem;
  }

  .nav-item {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.6rem 0.75rem;
    border-radius: 8px;
    color: var(--color-text-muted);
    font-size: 0.95rem;
    transition: background 0.15s, color 0.15s;
  }

  .nav-item:hover {
    background: var(--color-surface);
    color: var(--color-text);
    text-decoration: none;
  }

  .nav-item.active {
    background: var(--color-accent-glow);
    color: var(--color-accent);
    font-weight: 600;
  }

  .nav-item.logout:hover {
    color: #c62828;
  }

  .nav-icon {
    width: 1.2rem;
    text-align: center;
    font-size: 1rem;
  }

  .dashboard-main {
    padding: 3rem 3rem;
    overflow-y: auto;
  }

  @media (max-width: 720px) {
    .dashboard-layout {
      grid-template-columns: 1fr;
    }
    .dashboard-sidebar {
      border-right: none;
      border-bottom: 1px solid var(--color-border);
    }
  }
</style>
