---
import Dashboard from "../layouts/Dashboard.astro";
---

<Dashboard title="Dashboard -- shenas" description="Your shenas dashboard" active="overview">
  <div class="header">
    <h1>Welcome back<span id="user-name"></span></h1>
    <p class="subtitle" id="user-email"></p>
  </div>

  <div class="cards">
    <a href="/devices" class="card">
      <div class="card-icon">💻</div>
      <div class="card-body">
        <h3>Devices</h3>
        <p id="device-count">Manage your registered devices</p>
      </div>
    </a>
  </div>

  <div id="not-signed-in" class="notice" style="display:none">
    <p>You need to sign in to view your dashboard.</p>
    <a href="/api/auth/login" class="btn">Sign in with Google</a>
  </div>
</Dashboard>

<style>
  .header {
    margin-bottom: 2rem;
  }
  h1 {
    font-size: 1.8rem;
    color: var(--color-text);
    margin-bottom: 0.25rem;
  }
  .subtitle {
    color: var(--color-text-muted);
    font-size: 0.95rem;
  }
  .cards {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1rem;
  }
  .card {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1.25rem 1.5rem;
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    color: var(--color-text);
    transition:
      border-color 0.15s,
      transform 0.15s;
  }
  .card:hover {
    border-color: var(--color-accent);
    transform: translateY(-1px);
    text-decoration: none;
  }
  .card-icon {
    font-size: 1.5rem;
    width: 48px;
    height: 48px;
    background: var(--color-accent-glow);
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .card-body h3 {
    font-size: 1.05rem;
    margin-bottom: 0.2rem;
  }
  .card-body p {
    color: var(--color-text-muted);
    font-size: 0.85rem;
  }
  .notice {
    text-align: center;
    padding: 3rem;
    color: var(--color-text-muted);
  }
  .btn {
    display: inline-block;
    margin-top: 1rem;
    padding: 0.6rem 1.5rem;
    background: var(--color-accent);
    color: white;
    border-radius: 8px;
    font-weight: 600;
    font-size: 0.9rem;
  }
</style>

<script>
  async function load() {
    try {
      const r = await fetch("/api/auth/me", { credentials: "include" });
      const data = await r.json();
      if (!data.user) {
        document.getElementById("not-signed-in")!.style.display = "block";
        document.querySelector(".header")!.remove();
        document.querySelector(".cards")!.remove();
        return;
      }
      const name = data.user.name || data.user.email;
      document.getElementById("user-name")!.textContent = name ? `, ${name}` : "";
      document.getElementById("user-email")!.textContent = data.user.email || "";

      const devR = await fetch("/api/devices", { credentials: "include" });
      if (devR.ok) {
        const devs = await devR.json();
        const n = devs.length;
        document.getElementById("device-count")!.textContent = `${n} device${n !== 1 ? "s" : ""} registered`;
      }
    } catch {
      // ignore
    }
  }
  load();
</script>
