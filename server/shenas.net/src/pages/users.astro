---
import Dashboard from "../layouts/Dashboard.astro";
---

<Dashboard title="Users -- shenas" description="All registered users" active="users">
  <div class="header">
    <h1>Users</h1>
    <p class="subtitle" id="status">Loading...</p>
  </div>

  <div id="users-list" class="users-grid"></div>

  <div id="not-signed-in" class="notice" style="display:none">
    <p>Sign in to view users.</p>
    <a href="/api/auth/login" class="btn">Sign in with Google</a>
  </div>
</Dashboard>

<style is:global>
  .header {
    margin-bottom: 2rem;
  }
  .subtitle {
    color: var(--color-text-muted);
    font-size: 0.95rem;
  }
  .users-grid {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .user-card {
    background: var(--color-bg-card, #fff);
    border: 1px solid var(--color-border, #d8d4cc);
    border-radius: 12px;
    padding: 1.2rem 1.5rem;
    display: flex;
    align-items: center;
    gap: 1rem;
  }
  .user-avatar {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: var(--color-accent-glow, rgba(114, 143, 103, 0.12));
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.2rem;
    flex-shrink: 0;
    overflow: hidden;
  }
  .user-avatar img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .user-info {
    flex: 1;
  }
  .user-name {
    color: var(--color-text, #2c2c28);
    font-weight: 600;
    font-size: 1rem;
  }
  .user-email {
    color: var(--color-text-muted, #8a8780);
    font-size: 0.85rem;
    margin-top: 0.15rem;
  }
  .user-meta {
    color: var(--color-text-muted, #8a8780);
    font-size: 0.8rem;
    margin-top: 0.15rem;
  }
  .notice {
    text-align: center;
    padding: 3rem;
    color: var(--color-text-muted);
  }
  .btn {
    display: inline-block;
    margin-top: 1rem;
    padding: 0.6rem 1.5rem;
    background: var(--color-accent);
    color: white;
    border-radius: 8px;
    text-decoration: none;
    font-weight: 600;
    font-size: 0.9rem;
  }
  .empty {
    text-align: center;
    padding: 2rem;
    color: var(--color-text-muted);
    font-size: 0.9rem;
  }
</style>

<script>
  const list = document.getElementById("users-list")!;
  const status = document.getElementById("status")!;
  const notSignedIn = document.getElementById("not-signed-in")!;

  function timeAgo(dateStr: string): string {
    const diff = Date.now() - new Date(dateStr).getTime();
    const mins = Math.floor(diff / 60000);
    if (mins < 1) return "just now";
    if (mins < 60) return `${mins}m ago`;
    const hours = Math.floor(mins / 60);
    if (hours < 24) return `${hours}h ago`;
    const days = Math.floor(hours / 24);
    return `${days}d ago`;
  }

  async function loadUsers() {
    try {
      const authResp = await fetch("/api/auth/me", { credentials: "include" });
      const authData = await authResp.json();
      if (!authData.user) {
        status.style.display = "none";
        list.style.display = "none";
        notSignedIn.style.display = "block";
        return;
      }

      const resp = await fetch("/api/auth/users", { credentials: "include" });
      const users: Array<{
        id: string;
        email: string;
        name: string;
        picture: string;
        created_at: string;
        updated_at: string;
      }> = await resp.json();

      status.textContent = `${users.length} user${users.length !== 1 ? "s" : ""} registered`;

      if (users.length === 0) {
        list.innerHTML = '<div class="empty">No users registered yet.</div>';
        return;
      }

      list.innerHTML = users
        .map(
          (u) => `
        <div class="user-card">
          <div class="user-avatar">
            ${u.picture ? `<img src="${u.picture}" alt="" referrerpolicy="no-referrer" />` : "👤"}
          </div>
          <div class="user-info">
            <div class="user-name">${u.name || "Unnamed"}</div>
            <div class="user-email">${u.email}</div>
            <div class="user-meta">joined ${timeAgo(u.created_at)}${u.updated_at ? ` &middot; last active ${timeAgo(u.updated_at)}` : ""}</div>
          </div>
        </div>
      `,
        )
        .join("");
    } catch {
      status.textContent = "Failed to load users";
    }
  }

  loadUsers();
</script>
