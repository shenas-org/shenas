---
import Base from "../layouts/Base.astro";
---

<Base
  title="shenas -- we track everything so you can stop thinking about everything"
  description="Local-first edge intelligence that turns your health, finance, and lifestyle data into fulfillment -- without it ever leaving your device."
>
  <!-- Nav -->
  <nav>
    <div class="nav-inner">
      <a href="/" class="nav-logo">
        <img src="/favicon.svg" alt="shenas" width="28" height="28" />
        <span>shenas</span>
      </a>
      <div class="nav-links">
        <a href="#features">Features</a>
        <a href="#pipeline">How it works</a>
        <a href="#start">Get started</a>
        <a href="https://github.com/afuncke/shenas" class="nav-gh">GitHub</a>
      </div>
    </div>
  </nav>

  <!-- Hero -->
  <header class="hero">
    <div class="hero-glow"></div>
    <div class="container">
      <img src="/logo.svg" alt="shenas" class="hero-logo" />
      <h1>
        We track everything<br />
        so you can stop<br />
        <span class="gradient-text">thinking about everything.</span>
      </h1>
      <p class="hero-sub">
        Google and Meta use your data to predict what you'll buy.
        We use your data to predict what will make you happy.
        The brain lives on your device, not our server.
        Your data stays home -- only the wisdom travels.
      </p>
      <div class="hero-actions">
        <a href="#start" class="btn btn-primary">Get started</a>
        <a href="https://github.com/afuncke/shenas" class="btn btn-secondary">View on GitHub</a>
      </div>
    </div>
  </header>

  <!-- Data flow -->
  <section id="pipeline" class="section">
    <div class="container">
      <div class="section-header">
        <h2>From raw data to real fulfillment</h2>
        <p>
          Pipes sync data from your services, transforms normalize it into
          canonical schemas, and local-first AI finds patterns -- all without
          a single byte leaving your device. Like a coach who gives you the
          perfect plan without ever needing to see you undressed.
        </p>
      </div>
      <shenas-data-flow></shenas-data-flow>
    </div>
  </section>

  <!-- Features grid -->
  <section id="features" class="section">
    <div class="container">
      <div class="section-header">
        <h2>Edge intelligence for the rest of your life</h2>
        <p>
          Not productivity. Fulfillment. Every feature is designed to help
          you understand yourself better -- not optimize yourself into a
          spreadsheet.
        </p>
      </div>
      <div class="features-grid">
        <shenas-feature-card icon="AI" heading="Local-first AI">
          The brain lives on your device. Federated learning trains models
          across devices without centralizing data -- only gradients travel,
          your raw records never leave your machine.
        </shenas-feature-card>
        <shenas-feature-card icon="DB" heading="Your data stays home">
          All data lives in a local DuckDB database. No cloud accounts, no
          third-party sync. Back it up, move it, delete it -- it is a single
          file you own completely.
        </shenas-feature-card>
        <shenas-feature-card icon="OK" heading="Verified and trusted">
          Every extension is cryptographically signed before it reaches your
          system. You always know exactly what's running and where it came
          from. Trust by design, not by promise.
        </shenas-feature-card>
        <shenas-feature-card icon="ZZ" heading="Set it and forget it">
          After the initial setup, data flows automatically on your schedule.
          No manual exports, no spreadsheets, no remembering to sync.
          We track everything so you don't have to think about it.
        </shenas-feature-card>
        <shenas-feature-card icon="EQ" heading="One truth from many sources">
          Sleep from your watch meets mood from your journal meets spending
          from your bank. Every source feeds into a unified picture so you
          can see connections you'd never spot alone.
        </shenas-feature-card>
        <shenas-feature-card icon="YU" heading="Made for you, by you">
          Swap dashboards, add views, shape the experience. Your view of
          your life should look exactly like you want it to -- not like
          someone else's template.
        </shenas-feature-card>
      </div>
    </div>
  </section>

  <!-- Sources -->
  <section class="section section-alt">
    <div class="container">
      <div class="section-header">
        <h2>Connect what matters to you</h2>
        <p>
          Your health tracker, your bank, your journal, your calendar -- they
          all know a piece of you. Shenas brings the pieces together on your
          device so you can see the whole picture.
        </p>
      </div>
      <div class="sources-grid">
        <div class="source-card">
          <div class="source-name">Garmin</div>
          <div class="source-desc">HRV, sleep, steps, body composition, activities</div>
        </div>
        <div class="source-card">
          <div class="source-name">Spotify</div>
          <div class="source-desc">Listening history, PKCE OAuth, extended history import</div>
        </div>
        <div class="source-card">
          <div class="source-name">Gmail</div>
          <div class="source-desc">Email metadata and threads via OAuth2</div>
        </div>
        <div class="source-card">
          <div class="source-name">Google Calendar</div>
          <div class="source-desc">Events and schedules for time tracking</div>
        </div>
        <div class="source-card">
          <div class="source-name">Lunch Money</div>
          <div class="source-desc">Transactions, budgets, spending categories</div>
        </div>
        <div class="source-card">
          <div class="source-name">Obsidian</div>
          <div class="source-desc">Daily notes frontmatter -- mood, habits, journaling</div>
        </div>
        <div class="source-card">
          <div class="source-name">Duolingo</div>
          <div class="source-desc">Streaks, XP, and lesson progress</div>
        </div>
        <div class="source-card">
          <div class="source-name">Google Takeout</div>
          <div class="source-desc">Bulk import from Google data exports</div>
        </div>
        <div class="source-card source-card-add">
          <div class="source-name">Your source</div>
          <div class="source-desc">Write a pipe, publish a wheel, share with the community</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Get started -->
  <section id="start" class="section">
    <div class="container">
      <div class="section-header">
        <h2>Start in minutes</h2>
        <p>Three steps from zero to your first insight. Requires Python 3.12+ and <a href="https://docs.astral.sh/uv/">uv</a>.</p>
      </div>
      <div class="code-grid">
        <div class="code-step">
          <div class="step-number">1</div>
          <h3>Install</h3>
          <shenas-code-block title="terminal">
{`uv sync
make install`}
          </shenas-code-block>
        </div>
        <div class="code-step">
          <div class="step-number">2</div>
          <h3>Connect a source</h3>
          <shenas-code-block title="terminal">
{`shenasctl pipe add garmin
shenasctl pipe garmin auth
shenasctl pipe garmin sync`}
          </shenas-code-block>
        </div>
        <div class="code-step">
          <div class="step-number">3</div>
          <h3>Visualize</h3>
          <shenas-code-block title="terminal">
{`shenasctl component add fitness-dashboard
shenas`}
          </shenas-code-block>
        </div>
      </div>
    </div>
  </section>

  <!-- Architecture -->
  <section class="section section-alt">
    <div class="container">
      <div class="section-header">
        <h2>How it all fits together</h2>
        <p>
          Modular by design. Each piece handles one job well, and together
          they create a system that works quietly in the background.
        </p>
      </div>
      <div class="arch-grid">
        <div class="arch-card">
          <h3>Command line</h3>
          <p>A lightweight tool to connect sources, manage plugins, and control everything from the terminal.</p>
        </div>
        <div class="arch-card">
          <h3>Local server</h3>
          <p>Runs on your machine. Serves the dashboard, handles queries, discovers your plugins automatically.</p>
        </div>
        <div class="arch-card">
          <h3>Background sync</h3>
          <p>A daemon that checks your sources on schedule and syncs new data without you lifting a finger.</p>
        </div>
        <div class="arch-card">
          <h3>Plugin repository</h3>
          <p>Your own signed package server. Install trusted extensions with a single command.</p>
        </div>
        <div class="arch-card">
          <h3>Edge intelligence</h3>
          <p>Collaborative AI that learns across devices without sharing raw data. The wisdom travels, the data stays.</p>
        </div>
        <div class="arch-card">
          <h3>Desktop + Mobile</h3>
          <p>Native apps for Linux, macOS, Windows, and Android. Your data and your dashboard, wherever you are.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Footer -->
  <footer>
    <div class="container footer-inner">
      <div class="footer-logo">
        <img src="/favicon.svg" alt="shenas" width="24" height="24" />
        <span>shenas</span>
      </div>
      <div class="footer-links">
        <a href="https://github.com/afuncke/shenas">GitHub</a>
        <a href="https://github.com/afuncke/shenas/issues">Issues</a>
      </div>
      <p class="footer-copy">Your data stays home. Only the wisdom travels.</p>
    </div>
  </footer>
</Base>

<style>
  /* Nav */
  nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    background: rgba(10, 10, 15, 0.8);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--color-border);
  }

  .nav-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0.75rem 1.5rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .nav-logo {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-weight: 600;
    font-size: 1rem;
    color: var(--color-text);
    text-decoration: none;
  }

  .nav-links {
    display: flex;
    gap: 1.5rem;
    align-items: center;
  }

  .nav-links a {
    font-size: 0.85rem;
    color: var(--color-text-muted);
    text-decoration: none;
    transition: color 0.15s;
  }

  .nav-links a:hover {
    color: var(--color-text);
    text-decoration: none;
  }

  .nav-gh {
    padding: 0.35rem 0.9rem;
    border: 1px solid var(--color-border);
    border-radius: 8px;
    font-size: 0.8rem !important;
    transition: border-color 0.15s !important;
  }

  .nav-gh:hover {
    border-color: var(--color-accent) !important;
  }

  /* Hero */
  .hero {
    position: relative;
    padding: 10rem 1.5rem 6rem;
    text-align: center;
    overflow: hidden;
  }

  .hero-glow {
    position: absolute;
    top: -200px;
    left: 50%;
    transform: translateX(-50%);
    width: 800px;
    height: 600px;
    background: radial-gradient(ellipse, var(--color-accent-glow) 0%, transparent 70%);
    pointer-events: none;
  }

  .container {
    max-width: var(--max-width);
    margin: 0 auto;
    position: relative;
  }

  .hero-logo {
    width: 160px;
    height: 160px;
    border-radius: 24px;
    margin-bottom: 2rem;
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.06);
  }

  .badge {
    display: inline-block;
    padding: 0.4rem 1rem;
    border: 1px solid var(--color-border);
    border-radius: 100px;
    font-size: 0.8rem;
    color: var(--color-text-muted);
    margin-bottom: 2rem;
    letter-spacing: 0.02em;
  }

  h1 {
    font-size: clamp(2.5rem, 6vw, 4rem);
    font-weight: 700;
    line-height: 1.1;
    letter-spacing: -0.03em;
    margin-bottom: 1.5rem;
  }

  .gradient-text {
    background: linear-gradient(135deg, var(--color-warm), var(--color-accent-light));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero-sub {
    max-width: 640px;
    margin: 0 auto 2.5rem;
    font-size: 1.1rem;
    line-height: 1.7;
    color: var(--color-text-muted);
  }

  .hero-actions {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    padding: 0.7rem 1.5rem;
    border-radius: 10px;
    font-size: 0.9rem;
    font-weight: 500;
    text-decoration: none;
    transition: all 0.2s;
  }

  .btn-primary {
    background: var(--color-accent);
    color: white;
  }

  .btn-primary:hover {
    background: #628261;
    text-decoration: none;
    transform: translateY(-1px);
    box-shadow: 0 4px 16px var(--color-accent-glow);
  }

  .btn-secondary {
    background: var(--color-surface);
    color: var(--color-text);
    border: 1px solid var(--color-border);
  }

  .btn-secondary:hover {
    border-color: var(--color-accent);
    text-decoration: none;
    transform: translateY(-1px);
  }

  /* Sections */
  .section {
    padding: 6rem 1.5rem;
  }

  .section-alt {
    background: var(--color-bg-elevated);
  }

  .section-header {
    text-align: center;
    margin-bottom: 3.5rem;
  }

  .section-header h2 {
    font-size: clamp(1.5rem, 3vw, 2rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    margin-bottom: 1rem;
  }

  .section-header p {
    max-width: 560px;
    margin: 0 auto;
    color: var(--color-text-muted);
    font-size: 1rem;
    line-height: 1.6;
  }

  /* Features */
  .features-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 1.25rem;
  }

  /* Sources */
  .sources-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 1rem;
  }

  .source-card {
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    padding: 1.25rem;
    transition: border-color 0.2s;
  }

  .source-card:hover {
    border-color: var(--color-accent);
  }

  .source-name {
    font-weight: 600;
    font-size: 0.95rem;
    margin-bottom: 0.4rem;
  }

  .source-desc {
    font-size: 0.8rem;
    color: var(--color-text-muted);
    line-height: 1.5;
  }

  .source-card-add {
    border-style: dashed;
    background: transparent;
  }

  .source-card-add .source-name {
    color: var(--color-accent-light);
  }

  /* Code steps */
  .code-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 2rem;
  }

  .code-step {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .step-number {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.85rem;
    font-weight: 600;
    background: var(--color-accent-glow);
    color: var(--color-accent-light);
    border: 1px solid color-mix(in srgb, var(--color-accent-light) 25%, transparent);
  }

  .code-step h3 {
    font-size: 1rem;
    font-weight: 600;
  }

  /* Architecture */
  .arch-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 1.25rem;
  }

  .arch-card {
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    padding: 1.5rem;
    transition: border-color 0.2s;
  }

  .arch-card:hover {
    border-color: var(--color-accent);
  }

  .arch-card h3 {
    font-size: 0.95rem;
    font-weight: 600;
    margin-bottom: 0.5rem;
    font-family: var(--font-mono);
  }

  .arch-card p {
    font-size: 0.85rem;
    line-height: 1.6;
    color: var(--color-text-muted);
  }

  /* Footer */
  footer {
    border-top: 1px solid var(--color-border);
    padding: 2.5rem 1.5rem;
  }

  .footer-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .footer-logo {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-weight: 600;
    font-size: 0.9rem;
  }

  .footer-links {
    display: flex;
    gap: 1.5rem;
  }

  .footer-links a {
    font-size: 0.85rem;
    color: var(--color-text-muted);
  }

  .footer-copy {
    font-size: 0.8rem;
    color: var(--color-text-muted);
  }

  /* Mobile */
  @media (max-width: 640px) {
    .nav-links a:not(.nav-gh) {
      display: none;
    }

    .hero {
      padding: 8rem 1.5rem 4rem;
    }

    .hero-sub {
      font-size: 1rem;
    }

    .section {
      padding: 4rem 1.5rem;
    }

    .features-grid,
    .code-grid,
    .arch-grid {
      grid-template-columns: 1fr;
    }

    .footer-inner {
      flex-direction: column;
      text-align: center;
    }
  }
</style>

<script>
  import "../components/data-flow.ts";
  import "../components/feature-card.ts";
  import "../components/code-block.ts";
</script>
