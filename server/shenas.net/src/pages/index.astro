---
import Base from "../layouts/Base.astro";
---

<Base
  title="shenas -- we track everything so you can stop thinking about everything"
  description="Local-first edge intelligence that turns your health, finance, and lifestyle data into fulfillment -- without it ever leaving your device."
>
  <!-- Nav -->
  <nav>
    <div class="nav-inner">
      <a href="/" class="nav-logo">
        <img src="/logo-192.png" alt="shenas" width="28" height="28" />
        <span>shenas</span>
      </a>
      <div class="nav-links">
        <a href="#features">Features</a>
        <a href="#pipeline">How it works</a>
        <a href="#start">Get started</a>
        <a href="https://github.com/afuncke/shenas" class="nav-gh">GitHub</a>
      </div>
    </div>
  </nav>

  <!-- Hero -->
  <header class="hero">
    <div class="hero-glow"></div>
    <div class="container">
      <div class="badge">Open source / local-first / edge intelligence</div>
      <h1>
        We track everything<br />
        so you can stop<br />
        <span class="gradient-text">thinking about everything.</span>
      </h1>
      <p class="hero-sub">
        Google and Meta use your data to predict what you'll buy.
        We use your data to predict what will make you happy.
        The brain lives on your device, not our server.
        Your data stays home -- only the wisdom travels.
      </p>
      <div class="hero-actions">
        <a href="#start" class="btn btn-primary">Get started</a>
        <a href="https://github.com/afuncke/shenas" class="btn btn-secondary">View on GitHub</a>
      </div>
    </div>
  </header>

  <!-- Data flow -->
  <section id="pipeline" class="section">
    <div class="container">
      <div class="section-header">
        <h2>From raw data to real fulfillment</h2>
        <p>
          Pipes sync data from your services, transforms normalize it into
          canonical schemas, and local-first AI finds patterns -- all without
          a single byte leaving your device. Like a coach who gives you the
          perfect plan without ever needing to see you undressed.
        </p>
      </div>
      <shenas-data-flow></shenas-data-flow>
    </div>
  </section>

  <!-- Features grid -->
  <section id="features" class="section">
    <div class="container">
      <div class="section-header">
        <h2>Edge intelligence for the rest of your life</h2>
        <p>
          Not productivity. Fulfillment. Every feature is designed to help
          you understand yourself better -- not optimize yourself into a
          spreadsheet.
        </p>
      </div>
      <div class="features-grid">
        <shenas-feature-card icon="AI" heading="Local-first AI">
          The brain lives on your device. Federated learning trains models
          across devices without centralizing data -- only gradients travel,
          your raw records never leave your machine.
        </shenas-feature-card>
        <shenas-feature-card icon="DB" heading="Your data stays home">
          All data lives in a local DuckDB database. No cloud accounts, no
          third-party sync. Back it up, move it, delete it -- it is a single
          file you own completely.
        </shenas-feature-card>
        <shenas-feature-card icon="PK" heading="Signed plugin ecosystem">
          Pipes, schemas, and components are Ed25519-signed Python wheels
          served from a PEP 503 repository. Every install is verified before
          it touches your system.
        </shenas-feature-card>
        <shenas-feature-card icon="dlt" heading="Set it and forget it">
          Built on dlt with incremental cursors. After the initial sync, data
          flows automatically on schedule. We track everything so you don't
          have to think about it.
        </shenas-feature-card>
        <shenas-feature-card icon="TX" heading="One truth from many sources">
          Raw data from every service is transformed into shared metric schemas.
          Garmin HRV and Oura HRV land in the same table. Sleep from your watch
          meets mood from your journal. The picture completes itself.
        </shenas-feature-card>
        <shenas-feature-card icon="WC" heading="Pluggable and personal">
          The frontend is built with Lit web components distributed as wheels.
          Swap dashboards, add visualizations, build your own -- your view of
          your life should look exactly like you want it to.
        </shenas-feature-card>
      </div>
    </div>
  </section>

  <!-- Sources -->
  <section class="section section-alt">
    <div class="container">
      <div class="section-header">
        <h2>Connect what matters to you</h2>
        <p>
          Your health tracker, your bank, your journal, your calendar -- they
          all know a piece of you. Shenas brings the pieces together on your
          device so you can see the whole picture.
        </p>
      </div>
      <div class="sources-grid">
        <div class="source-card">
          <div class="source-name">Garmin</div>
          <div class="source-desc">HRV, sleep, steps, body composition, activities</div>
        </div>
        <div class="source-card">
          <div class="source-name">Spotify</div>
          <div class="source-desc">Listening history, PKCE OAuth, extended history import</div>
        </div>
        <div class="source-card">
          <div class="source-name">Gmail</div>
          <div class="source-desc">Email metadata and threads via OAuth2</div>
        </div>
        <div class="source-card">
          <div class="source-name">Google Calendar</div>
          <div class="source-desc">Events and schedules for time tracking</div>
        </div>
        <div class="source-card">
          <div class="source-name">Lunch Money</div>
          <div class="source-desc">Transactions, budgets, spending categories</div>
        </div>
        <div class="source-card">
          <div class="source-name">Obsidian</div>
          <div class="source-desc">Daily notes frontmatter -- mood, habits, journaling</div>
        </div>
        <div class="source-card">
          <div class="source-name">Duolingo</div>
          <div class="source-desc">Streaks, XP, and lesson progress</div>
        </div>
        <div class="source-card">
          <div class="source-name">Google Takeout</div>
          <div class="source-desc">Bulk import from Google data exports</div>
        </div>
        <div class="source-card source-card-add">
          <div class="source-name">Your source</div>
          <div class="source-desc">Write a pipe, publish a wheel, share with the community</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Get started -->
  <section id="start" class="section">
    <div class="container">
      <div class="section-header">
        <h2>Up and running in three commands</h2>
        <p>Requires Python 3.12+ and <a href="https://docs.astral.sh/uv/">uv</a>.</p>
      </div>
      <div class="code-grid">
        <div class="code-step">
          <div class="step-number">1</div>
          <h3>Install</h3>
          <shenas-code-block title="terminal">
{`uv sync
make install`}
          </shenas-code-block>
        </div>
        <div class="code-step">
          <div class="step-number">2</div>
          <h3>Connect a source</h3>
          <shenas-code-block title="terminal">
{`shenasctl pipe add garmin
shenasctl pipe garmin auth
shenasctl pipe garmin sync`}
          </shenas-code-block>
        </div>
        <div class="code-step">
          <div class="step-number">3</div>
          <h3>Visualize</h3>
          <shenas-code-block title="terminal">
{`shenasctl component add fitness-dashboard
shenas`}
          </shenas-code-block>
        </div>
      </div>
    </div>
  </section>

  <!-- Architecture -->
  <section class="section section-alt">
    <div class="container">
      <div class="section-header">
        <h2>Architecture</h2>
        <p>
          A uv monorepo with glob-based workspace members. Every piece is a
          separate package with its own version, build, and test suite.
        </p>
      </div>
      <div class="arch-grid">
        <div class="arch-card">
          <h3>shenasctl</h3>
          <p>Lightweight CLI client. httpx + typer + cryptography. No server dependencies.</p>
        </div>
        <div class="arch-card">
          <h3>shenas-app</h3>
          <p>FastAPI UI server. Discovers plugins via entry points, serves Arrow IPC queries.</p>
        </div>
        <div class="arch-card">
          <h3>shenas-scheduler</h3>
          <p>Background sync daemon. Polls for due pipes and runs them on schedule.</p>
        </div>
        <div class="arch-card">
          <h3>shenas-repository</h3>
          <p>PEP 503 package server with Ed25519 signing. Your own private PyPI for plugins.</p>
        </div>
        <div class="arch-card">
          <h3>Federated learning</h3>
          <p>Flower-based FL coordinator and client. PyTorch training with model plugin registry.</p>
        </div>
        <div class="arch-card">
          <h3>Desktop + Mobile</h3>
          <p>Tauri v2 apps. Desktop bundles PyInstaller sidecars, mobile runs Rust-native with axum + DuckDB.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Footer -->
  <footer>
    <div class="container footer-inner">
      <div class="footer-logo">
        <img src="/logo-192.png" alt="shenas" width="24" height="24" />
        <span>shenas</span>
      </div>
      <div class="footer-links">
        <a href="https://github.com/afuncke/shenas">GitHub</a>
        <a href="https://github.com/afuncke/shenas/issues">Issues</a>
      </div>
      <p class="footer-copy">Your data stays home. Only the wisdom travels.</p>
    </div>
  </footer>
</Base>

<style>
  /* Nav */
  nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    background: rgba(10, 10, 15, 0.8);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--color-border);
  }

  .nav-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0.75rem 1.5rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .nav-logo {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-weight: 600;
    font-size: 1rem;
    color: var(--color-text);
    text-decoration: none;
  }

  .nav-links {
    display: flex;
    gap: 1.5rem;
    align-items: center;
  }

  .nav-links a {
    font-size: 0.85rem;
    color: var(--color-text-muted);
    text-decoration: none;
    transition: color 0.15s;
  }

  .nav-links a:hover {
    color: var(--color-text);
    text-decoration: none;
  }

  .nav-gh {
    padding: 0.35rem 0.9rem;
    border: 1px solid var(--color-border);
    border-radius: 8px;
    font-size: 0.8rem !important;
    transition: border-color 0.15s !important;
  }

  .nav-gh:hover {
    border-color: var(--color-accent) !important;
  }

  /* Hero */
  .hero {
    position: relative;
    padding: 10rem 1.5rem 6rem;
    text-align: center;
    overflow: hidden;
  }

  .hero-glow {
    position: absolute;
    top: -200px;
    left: 50%;
    transform: translateX(-50%);
    width: 800px;
    height: 600px;
    background: radial-gradient(ellipse, var(--color-accent-glow) 0%, transparent 70%);
    pointer-events: none;
  }

  .container {
    max-width: var(--max-width);
    margin: 0 auto;
    position: relative;
  }

  .badge {
    display: inline-block;
    padding: 0.4rem 1rem;
    border: 1px solid var(--color-border);
    border-radius: 100px;
    font-size: 0.8rem;
    color: var(--color-text-muted);
    margin-bottom: 2rem;
    letter-spacing: 0.02em;
  }

  h1 {
    font-size: clamp(2.5rem, 6vw, 4rem);
    font-weight: 700;
    line-height: 1.1;
    letter-spacing: -0.03em;
    margin-bottom: 1.5rem;
  }

  .gradient-text {
    background: linear-gradient(135deg, var(--color-accent-light), var(--color-green));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero-sub {
    max-width: 640px;
    margin: 0 auto 2.5rem;
    font-size: 1.1rem;
    line-height: 1.7;
    color: var(--color-text-muted);
  }

  .hero-actions {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    padding: 0.7rem 1.5rem;
    border-radius: 10px;
    font-size: 0.9rem;
    font-weight: 500;
    text-decoration: none;
    transition: all 0.2s;
  }

  .btn-primary {
    background: var(--color-accent);
    color: white;
  }

  .btn-primary:hover {
    background: #5a4bd4;
    text-decoration: none;
    transform: translateY(-1px);
    box-shadow: 0 4px 16px var(--color-accent-glow);
  }

  .btn-secondary {
    background: var(--color-surface);
    color: var(--color-text);
    border: 1px solid var(--color-border);
  }

  .btn-secondary:hover {
    border-color: var(--color-accent);
    text-decoration: none;
    transform: translateY(-1px);
  }

  /* Sections */
  .section {
    padding: 6rem 1.5rem;
  }

  .section-alt {
    background: var(--color-bg-elevated);
  }

  .section-header {
    text-align: center;
    margin-bottom: 3.5rem;
  }

  .section-header h2 {
    font-size: clamp(1.5rem, 3vw, 2rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    margin-bottom: 1rem;
  }

  .section-header p {
    max-width: 560px;
    margin: 0 auto;
    color: var(--color-text-muted);
    font-size: 1rem;
    line-height: 1.6;
  }

  /* Features */
  .features-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 1.25rem;
  }

  /* Sources */
  .sources-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 1rem;
  }

  .source-card {
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    padding: 1.25rem;
    transition: border-color 0.2s;
  }

  .source-card:hover {
    border-color: var(--color-accent);
  }

  .source-name {
    font-weight: 600;
    font-size: 0.95rem;
    margin-bottom: 0.4rem;
  }

  .source-desc {
    font-size: 0.8rem;
    color: var(--color-text-muted);
    line-height: 1.5;
  }

  .source-card-add {
    border-style: dashed;
    background: transparent;
  }

  .source-card-add .source-name {
    color: var(--color-accent-light);
  }

  /* Code steps */
  .code-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 2rem;
  }

  .code-step {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .step-number {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.85rem;
    font-weight: 600;
    background: var(--color-accent-glow);
    color: var(--color-accent-light);
    border: 1px solid color-mix(in srgb, var(--color-accent-light) 25%, transparent);
  }

  .code-step h3 {
    font-size: 1rem;
    font-weight: 600;
  }

  /* Architecture */
  .arch-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 1.25rem;
  }

  .arch-card {
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    padding: 1.5rem;
    transition: border-color 0.2s;
  }

  .arch-card:hover {
    border-color: var(--color-accent);
  }

  .arch-card h3 {
    font-size: 0.95rem;
    font-weight: 600;
    margin-bottom: 0.5rem;
    font-family: var(--font-mono);
  }

  .arch-card p {
    font-size: 0.85rem;
    line-height: 1.6;
    color: var(--color-text-muted);
  }

  /* Footer */
  footer {
    border-top: 1px solid var(--color-border);
    padding: 2.5rem 1.5rem;
  }

  .footer-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .footer-logo {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-weight: 600;
    font-size: 0.9rem;
  }

  .footer-links {
    display: flex;
    gap: 1.5rem;
  }

  .footer-links a {
    font-size: 0.85rem;
    color: var(--color-text-muted);
  }

  .footer-copy {
    font-size: 0.8rem;
    color: var(--color-text-muted);
  }

  /* Mobile */
  @media (max-width: 640px) {
    .nav-links a:not(.nav-gh) {
      display: none;
    }

    .hero {
      padding: 8rem 1.5rem 4rem;
    }

    .hero-sub {
      font-size: 1rem;
    }

    .section {
      padding: 4rem 1.5rem;
    }

    .features-grid,
    .code-grid,
    .arch-grid {
      grid-template-columns: 1fr;
    }

    .footer-inner {
      flex-direction: column;
      text-align: center;
    }
  }
</style>

<script>
  import "../components/data-flow.ts";
  import "../components/feature-card.ts";
  import "../components/code-block.ts";
</script>
