---
import Dashboard from "../layouts/Dashboard.astro";
---

<Dashboard title="Devices -- shenas" description="Manage your registered devices" active="devices">
  <div class="header">
    <h1>Your Devices</h1>
    <p class="subtitle" id="status">Loading...</p>
  </div>

  <div id="devices-list" class="devices-grid"></div>

  <div id="not-signed-in" class="notice" style="display:none">
    <p>Sign in to view your devices.</p>
    <a href="/api/auth/login" class="btn">Sign in with Google</a>
  </div>
</Dashboard>

<style is:global>
  .header {
    margin-bottom: 2rem;
  }
  .devices-page h1 {
    font-size: 1.8rem;
    color: var(--color-text);
    margin-bottom: 0.25rem;
  }
  .subtitle {
    color: var(--color-text-muted);
    font-size: 0.95rem;
  }
  .devices-grid {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .device-card {
    background: var(--color-bg-card, #fff);
    border: 1px solid var(--color-border, #d8d4cc);
    border-radius: 12px;
    padding: 1.2rem 1.5rem;
    display: flex;
    align-items: center;
    gap: 1rem;
  }
  .device-icon {
    width: 40px;
    height: 40px;
    border-radius: 10px;
    background: var(--color-accent-glow, rgba(114, 143, 103, 0.12));
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.2rem;
    flex-shrink: 0;
  }
  .device-info {
    flex: 1;
  }
  .device-name {
    color: var(--color-text, #2c2c28);
    font-weight: 600;
    font-size: 1rem;
  }
  .device-meta {
    color: var(--color-text-muted, #8a8780);
    font-size: 0.8rem;
    margin-top: 0.2rem;
  }
  .device-actions {
    flex-shrink: 0;
  }
  .btn-remove {
    background: none;
    border: 1px solid var(--color-border, #d8d4cc);
    color: var(--color-text-muted, #8a8780);
    padding: 0.3rem 0.8rem;
    border-radius: 6px;
    font-size: 0.75rem;
    cursor: pointer;
    transition: all 0.2s;
  }
  .btn-remove:hover {
    border-color: #c62828;
    color: #c62828;
  }
  .notice {
    text-align: center;
    padding: 3rem;
    color: var(--color-text-muted);
  }
  .btn {
    display: inline-block;
    margin-top: 1rem;
    padding: 0.6rem 1.5rem;
    background: var(--color-accent);
    color: white;
    border-radius: 8px;
    text-decoration: none;
    font-weight: 600;
    font-size: 0.9rem;
  }
  .empty {
    text-align: center;
    padding: 2rem;
    color: var(--color-text-muted);
    font-size: 0.9rem;
  }
</style>

<script>
  const list = document.getElementById("devices-list")!;
  const status = document.getElementById("status")!;
  const notSignedIn = document.getElementById("not-signed-in")!;

  const deviceIcons: Record<string, string> = {
    desktop: "\u{1F5A5}",
    laptop: "\u{1F4BB}",
    mobile: "\u{1F4F1}",
    tablet: "\u{1F4F1}",
    server: "\u{2601}",
  };

  function timeAgo(dateStr: string): string {
    const diff = Date.now() - new Date(dateStr).getTime();
    const mins = Math.floor(diff / 60000);
    if (mins < 1) return "just now";
    if (mins < 60) return `${mins}m ago`;
    const hours = Math.floor(mins / 60);
    if (hours < 24) return `${hours}h ago`;
    const days = Math.floor(hours / 24);
    return `${days}d ago`;
  }

  async function removeDevice(id: string) {
    await fetch(`/api/devices/${id}`, { method: "DELETE", credentials: "include" });
    loadDevices();
  }

  async function loadDevices() {
    try {
      const authResp = await fetch("/api/auth/me", { credentials: "include" });
      const authData = await authResp.json();
      if (!authData.user) {
        status.style.display = "none";
        list.style.display = "none";
        notSignedIn.style.display = "block";
        return;
      }

      const resp = await fetch("/api/devices", { credentials: "include" });
      const devices: Array<{
        id: string;
        name: string;
        device_type: string;
        last_seen: string;
        created_at: string;
      }> = await resp.json();

      status.textContent = `${devices.length} device${devices.length !== 1 ? "s" : ""} registered`;

      if (devices.length === 0) {
        list.innerHTML = '<div class="empty">No devices registered yet. Install shenas on a device to get started.</div>';
        return;
      }

      list.innerHTML = devices
        .map(
          (d) => `
        <div class="device-card">
          <div class="device-icon">${deviceIcons[d.device_type] || "\u{1F4BB}"}</div>
          <div class="device-info">
            <div class="device-name">${d.name}</div>
            <div class="device-meta">${d.device_type} &middot; last seen ${timeAgo(d.last_seen)} &middot; added ${timeAgo(d.created_at)}</div>
          </div>
          <div class="device-actions">
            <button class="btn-remove" onclick="window.__removeDevice('${d.id}')">Remove</button>
          </div>
        </div>
      `,
        )
        .join("");
    } catch {
      status.textContent = "Failed to load devices";
    }
  }

  (window as any).__removeDevice = removeDevice;
  loadDevices();
</script>
