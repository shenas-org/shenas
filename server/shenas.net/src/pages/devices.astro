---
import Dashboard from "../layouts/Dashboard.astro";
---

<Dashboard title="My Devices & Workers -- shenas" description="Manage your registered devices and workers" active="devices">
  <div class="header">
    <h1>My Devices & Workers</h1>
    <p class="subtitle" id="status">Loading...</p>
  </div>

  <div id="devices-list" class="devices-grid"></div>

  <div class="header" style="margin-top: 2.5rem">
    <h2>Cloud Workers</h2>
    <p class="subtitle" id="workers-status">Loading...</p>
  </div>

  <div id="workers-list" class="devices-grid"></div>

  <button id="deploy-worker-btn" class="btn" style="display:none; margin-top: 1rem">Deploy Worker</button>

  <div id="not-signed-in" class="notice" style="display:none">
    <p>Sign in to view your devices.</p>
    <a href="/api/auth/login" class="btn">Sign in with Google</a>
  </div>
</Dashboard>

<style is:global>
  .header {
    margin-bottom: 2rem;
  }
  .devices-page h1 {
    font-size: 1.8rem;
    color: var(--color-text);
    margin-bottom: 0.25rem;
  }
  .subtitle {
    color: var(--color-text-muted);
    font-size: 0.95rem;
  }
  .devices-grid {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .device-card {
    background: var(--color-bg-card, #fff);
    border: 1px solid var(--color-border, #d8d4cc);
    border-radius: 12px;
    padding: 1.2rem 1.5rem;
    display: flex;
    align-items: center;
    gap: 1rem;
  }
  .device-icon {
    width: 40px;
    height: 40px;
    border-radius: 10px;
    background: var(--color-accent-glow, rgba(114, 143, 103, 0.12));
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.2rem;
    flex-shrink: 0;
  }
  .device-info {
    flex: 1;
  }
  .device-name {
    color: var(--color-text, #2c2c28);
    font-weight: 600;
    font-size: 1rem;
  }
  .device-meta {
    color: var(--color-text-muted, #8a8780);
    font-size: 0.8rem;
    margin-top: 0.2rem;
  }
  .device-actions {
    flex-shrink: 0;
  }
  .btn-remove {
    background: none;
    border: 1px solid var(--color-border, #d8d4cc);
    color: var(--color-text-muted, #8a8780);
    padding: 0.3rem 0.8rem;
    border-radius: 6px;
    font-size: 0.75rem;
    cursor: pointer;
    transition: all 0.2s;
  }
  .btn-remove:hover {
    border-color: #c62828;
    color: #c62828;
  }
  .notice {
    text-align: center;
    padding: 3rem;
    color: var(--color-text-muted);
  }
  .btn {
    display: inline-block;
    margin-top: 1rem;
    padding: 0.6rem 1.5rem;
    background: var(--color-accent);
    color: white;
    border-radius: 8px;
    text-decoration: none;
    font-weight: 600;
    font-size: 0.9rem;
  }
  .empty {
    text-align: center;
    padding: 2rem;
    color: var(--color-text-muted);
    font-size: 0.9rem;
  }
  .status-badge {
    display: inline-block;
    padding: 0.15rem 0.5rem;
    border-radius: 4px;
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
  }
  .status-Running { background: #e8f5e9; color: #2e7d32; }
  .status-Pending { background: #fff3e0; color: #e65100; }
  .status-Failed, .status-NotFound { background: #ffebee; color: #c62828; }
  .status-Unknown { background: #f5f5f5; color: #757575; }
</style>

<script>
  const list = document.getElementById("devices-list")!;
  const status = document.getElementById("status")!;
  const notSignedIn = document.getElementById("not-signed-in")!;

  const deviceIcons: Record<string, string> = {
    desktop: "\u{1F5A5}",
    laptop: "\u{1F4BB}",
    mobile: "\u{1F4F1}",
    tablet: "\u{1F4F1}",
    server: "\u{2601}",
  };

  function timeAgo(dateStr: string): string {
    const diff = Date.now() - new Date(dateStr).getTime();
    const mins = Math.floor(diff / 60000);
    if (mins < 1) return "just now";
    if (mins < 60) return `${mins}m ago`;
    const hours = Math.floor(mins / 60);
    if (hours < 24) return `${hours}h ago`;
    const days = Math.floor(hours / 24);
    return `${days}d ago`;
  }

  async function removeDevice(id: string) {
    await fetch(`/api/devices/${id}`, { method: "DELETE", credentials: "include" });
    loadDevices();
  }

  async function loadDevices() {
    try {
      const authResp = await fetch("/api/auth/me", { credentials: "include" });
      const authData = await authResp.json();
      if (!authData.user) {
        status.style.display = "none";
        list.style.display = "none";
        notSignedIn.style.display = "block";
        return;
      }

      const resp = await fetch("/api/devices", { credentials: "include" });
      const devices: Array<{
        id: string;
        name: string;
        device_type: string;
        last_seen: string;
        created_at: string;
      }> = await resp.json();

      status.textContent = `${devices.length} device${devices.length !== 1 ? "s" : ""} registered`;

      if (devices.length === 0) {
        list.innerHTML = '<div class="empty">No devices registered yet. Install shenas on a device to get started.</div>';
        return;
      }

      list.innerHTML = devices
        .map(
          (d) => `
        <div class="device-card">
          <div class="device-icon">${deviceIcons[d.device_type] || "\u{1F4BB}"}</div>
          <div class="device-info">
            <div class="device-name">${d.name}</div>
            <div class="device-meta">${d.device_type} &middot; last seen ${timeAgo(d.last_seen)} &middot; added ${timeAgo(d.created_at)}</div>
          </div>
          <div class="device-actions">
            <button class="btn-remove" onclick="window.__removeDevice('${d.id}')">Remove</button>
          </div>
        </div>
      `,
        )
        .join("");
    } catch {
      status.textContent = "Failed to load devices";
    }
  }

  // Workers
  const workersList = document.getElementById("workers-list")!;
  const workersStatus = document.getElementById("workers-status")!;
  const deployBtn = document.getElementById("deploy-worker-btn")!;

  async function loadWorkers() {
    try {
      const resp = await fetch("/api/workers", { credentials: "include" });
      if (!resp.ok) return;
      const workers: Array<{
        id: string;
        name: string;
        status: string;
        created_at: string;
      }> = await resp.json();

      workersStatus.textContent = `${workers.length} worker${workers.length !== 1 ? "s" : ""} deployed`;
      deployBtn.style.display = "inline-block";

      if (workers.length === 0) {
        workersList.innerHTML = '<div class="empty">No cloud workers deployed. Click "Deploy Worker" to create one.</div>';
        return;
      }

      workersList.innerHTML = workers
        .map(
          (w) => `
        <div class="device-card">
          <div class="device-icon">\u{2601}</div>
          <div class="device-info">
            <div class="device-name">${w.name} <span class="status-badge status-${w.status}">${w.status}</span></div>
            <div class="device-meta">cloud worker &middot; created ${timeAgo(w.created_at)}</div>
          </div>
          <div class="device-actions">
            <button class="btn-remove" onclick="window.__deleteWorker('${w.id}')">Delete</button>
          </div>
        </div>
      `,
        )
        .join("");
    } catch {
      workersStatus.textContent = "Failed to load workers";
    }
  }

  async function deployWorker() {
    deployBtn.textContent = "Deploying...";
    (deployBtn as HTMLButtonElement).disabled = true;
    try {
      const resp = await fetch("/api/workers", {
        method: "POST",
        credentials: "include",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ name: "cloud-worker" }),
      });
      if (!resp.ok) {
        const err = await resp.json();
        alert(`Deploy failed: ${err.error || "Unknown error"}`);
        return;
      }
      loadWorkers();
    } catch (e) {
      alert(`Deploy failed: ${e}`);
    } finally {
      deployBtn.textContent = "Deploy Worker";
      (deployBtn as HTMLButtonElement).disabled = false;
    }
  }

  async function deleteWorker(id: string) {
    if (!confirm("Delete this worker? This will stop and remove the container.")) return;
    await fetch(`/api/workers/${id}`, { method: "DELETE", credentials: "include" });
    loadWorkers();
  }

  deployBtn.addEventListener("click", deployWorker);
  (window as any).__removeDevice = removeDevice;
  (window as any).__deleteWorker = deleteWorker;
  loadDevices();
  loadWorkers();
</script>
