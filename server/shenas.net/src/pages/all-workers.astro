---
import Dashboard from "../layouts/Dashboard.astro";
---

<Dashboard title="Workers -- shenas" description="All deployed workers across all users" active="all-workers">
  <div class="header">
    <h1>Workers</h1>
    <p class="subtitle" id="status">Loading...</p>
  </div>

  <div id="workers-list" class="workers-grid"></div>

  <div id="not-signed-in" class="notice" style="display:none">
    <p>Sign in to view workers.</p>
    <a href="/api/auth/login" class="btn">Sign in with Google</a>
  </div>
</Dashboard>

<style is:global>
  .header { margin-bottom: 2rem; }
  .subtitle { color: var(--color-text-muted); font-size: 0.95rem; }
  .workers-grid { display: flex; flex-direction: column; gap: 1rem; }
  .worker-card {
    background: var(--color-bg-card, #fff);
    border: 1px solid var(--color-border, #d8d4cc);
    border-radius: 12px;
    padding: 1.2rem 1.5rem;
    display: flex;
    align-items: center;
    gap: 1rem;
  }
  .worker-icon {
    width: 40px; height: 40px; border-radius: 10px;
    background: var(--color-accent-glow, rgba(114, 143, 103, 0.12));
    display: flex; align-items: center; justify-content: center;
    font-size: 1.2rem; flex-shrink: 0;
  }
  .worker-info { flex: 1; }
  .worker-name { color: var(--color-text); font-weight: 600; font-size: 1rem; }
  .worker-owner { color: var(--color-accent); font-size: 0.8rem; margin-top: 0.15rem; }
  .worker-meta { color: var(--color-text-muted); font-size: 0.8rem; margin-top: 0.2rem; }
  .notice { text-align: center; padding: 3rem; color: var(--color-text-muted); }
  .btn {
    display: inline-block; margin-top: 1rem; padding: 0.6rem 1.5rem;
    background: var(--color-accent); color: white; border-radius: 8px;
    text-decoration: none; font-weight: 600; font-size: 0.9rem;
  }
  .empty { text-align: center; padding: 2rem; color: var(--color-text-muted); font-size: 0.9rem; }
  .status-badge {
    display: inline-block; padding: 0.15rem 0.5rem; border-radius: 4px;
    font-size: 0.7rem; font-weight: 600; text-transform: uppercase;
  }
  .status-Running { background: #e8f5e9; color: #2e7d32; }
  .status-Pending { background: #fff3e0; color: #e65100; }
  .status-Failed, .status-NotFound { background: #ffebee; color: #c62828; }
  .status-Unknown { background: #f5f5f5; color: #757575; }
</style>

<script>
  const list = document.getElementById("workers-list")!;
  const status = document.getElementById("status")!;
  const notSignedIn = document.getElementById("not-signed-in")!;

  function timeAgo(dateStr: string): string {
    const diff = Date.now() - new Date(dateStr).getTime();
    const mins = Math.floor(diff / 60000);
    if (mins < 1) return "just now";
    if (mins < 60) return `${mins}m ago`;
    const hours = Math.floor(mins / 60);
    if (hours < 24) return `${hours}h ago`;
    return `${Math.floor(hours / 24)}d ago`;
  }

  async function loadAllWorkers() {
    try {
      const authResp = await fetch("/api/auth/me", { credentials: "include" });
      const authData = await authResp.json();
      if (!authData.user) {
        status.style.display = "none";
        list.style.display = "none";
        notSignedIn.style.display = "block";
        return;
      }

      const resp = await fetch("/api/workers/all", { credentials: "include" });
      if (resp.status === 403) {
        list.innerHTML = '<div class="empty">Admin access required.</div>';
        status.textContent = "";
        return;
      }
      const workers: Array<{
        id: string;
        name: string;
        deployment_name: string;
        status: string;
        owner_name: string;
        owner_email: string;
        created_at: string;
      }> = await resp.json();

      status.textContent = `${workers.length} worker${workers.length !== 1 ? "s" : ""} across all users`;

      if (workers.length === 0) {
        list.innerHTML = '<div class="empty">No workers deployed yet.</div>';
        return;
      }

      list.innerHTML = workers
        .map(
          (w) => `
        <div class="worker-card">
          <div class="worker-icon">&#x2601;</div>
          <div class="worker-info">
            <div class="worker-name">${w.name} <span class="status-badge status-${w.status}">${w.status}</span></div>
            <div class="worker-owner">${w.owner_name || w.owner_email}</div>
            <div class="worker-meta">${w.deployment_name} &middot; created ${timeAgo(w.created_at)}</div>
          </div>
        </div>
      `,
        )
        .join("");
    } catch {
      status.textContent = "Failed to load workers";
    }
  }

  loadAllWorkers();
</script>
