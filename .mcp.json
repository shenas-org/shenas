{
  "mcpServers": {
    "duckdb": {
      "type": "stdio",
      "command": "uvx",
      "args": [
        "mcp-server-motherduck",
        "--db-path",
        "./data/shenas.duckdb",
        "--read-write"
      ],
      "env": {}
    },
    "discourse": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@discourse/mcp@latest"
      ],
      "env": {
        "DISCOURSE_URL": "",
        "DISCOURSE_API_KEY": ""
      }
    }
  }
}