#!/usr/bin/env bash
set -e

branch=$(git rev-parse --abbrev-ref HEAD)
if [ "$branch" = "main" ]; then
  echo "Direct commits to main are not allowed. Use a feature branch."
  exit 1
fi

echo "Running ruff check..."
uv run ruff check .

echo "Running ruff format check..."
uv run ruff format --check .

echo "Running ty check..."
uv run ty check server/repository/ app/ --exclude "**/vendor/**" --exclude "**/fl/**" --exclude "**/telemetry/**" --exclude "**/graphql/**" --extra-search-path server/repository

# Check FL modules only if torch is installed
if uv run python -c "import torch" 2>/dev/null; then
  echo "Running ty check (FL)..."
  uv run ty check app/fl/
fi

echo "All checks passed."
