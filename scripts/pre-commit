#!/usr/bin/env bash
set -e

branch=$(git rev-parse --abbrev-ref HEAD)
if [ "$branch" = "main" ]; then
  echo "Direct commits to main are not allowed. Use a feature branch."
  exit 1
fi

echo "Running ruff check..."
uv run ruff check .

echo "Running ruff format check..."
uv run ruff format --check .

echo "Running ty check..."
uv run ty check app/ --exclude "**/vendor/**" --exclude "**/fl/**" --exclude "**/telemetry/**" --exclude "**/graphql/**" --exclude "app/tests/**"

# Check FL modules only if torch is installed
if uv run python -c "import torch" 2>/dev/null; then
  echo "Running ty check (FL)..."
  uv run ty check app/fl/
fi

# Lint + format check staged TypeScript files
TS_FILES=$(git diff --cached --name-only --diff-filter=ACMR -- '*.ts' | grep -v '\.d\.ts$' || true)
if [ -n "$TS_FILES" ]; then
  echo "Running eslint on staged TS files..."
  npx eslint $TS_FILES
  echo "Running prettier check on staged TS files..."
  npx prettier --check $TS_FILES
fi

echo "All checks passed."
