"""Copybara config: sync shenas/shenas-net (private) -> shenas/shenas (public OSS).

Strips server infra, FL, mesh, and desktop/mobile paths.
The OSS repo includes the full local app with LLM/literature/analysis
support (users provide their own API key or sign up for premium).
"""

core.workflow(
    name = "default",
    origin = git.origin(
        url = "git@github.com:shenas-net/shenas.git",
        ref = "main",
    ),
    destination = git.github_destination(
        url = "git@github.com:shenas-org/shenas.git",
        push = "main",
    ),
    authoring = authoring.pass_thru("shenas <noreply@shenas.net>"),
    mode = "SQUASH",
    origin_files = glob(
        include = ["**"],
        exclude = [
            # Server-side (API, FL, deploy, repository, websites)
            "server/**",

            # Federated learning client
            "app/fl/**",

            # Mesh / device sync
            "app/mesh/**",

            # Google OAuth secrets (should be env vars, not in source)
            "plugins/sources/core/shenas_sources/core/google_auth.py",

            # Copybara config itself
            ".copybara/**",

            # CI/CD, monorepo tooling, internal docs
            ".github/**",
            ".moon/**",
            ".mcp.json",
            "Makefile",
            "README.md",
            "CLAUDE.md",
            "DESIGN.md",
            "DISCOURSE.md",
            "**/moon.yml",
            "scripts/**",

            # Lock files (generated, large)
            "uv.lock",
            "package-lock.json",

            # Desktop / mobile (not ready for OSS yet)
            "app/desktop/**",
            "app/mobile/**",
        ],
    ),
    transformations = [
        metadata.squash_notes(
            prefix = "Release sync\n\n",
            show_author = False,
            compact = True,
        ),
        # Use OSS-specific README and Makefile.
        core.move("README-oss.md", "README.md"),
        core.move("Makefile-oss", "Makefile"),
        # Strip private-only section from .gitignore.
        core.replace(
            before = "# PRIVATE-ONLY (stripped by Copybara)${x}",
            after = "",
            regex_groups = {"x": "[\\s\\S]*"},
            multiline = True,
            paths = glob([".gitignore"]),
        ),
    ],
)
